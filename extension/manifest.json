{
  "manifest_version": 3,
  "name": "TrackAli",
  "version": "2.0.0",
  "description": "Import AliExpress order history into the local TrackAli dashboard.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.aliexpress.com/*",
    "https://*.aliexpress.com/*",
    "https://acs.aliexpress.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.aliexpress.com/*", "https://*.aliexpress.com/*"],
      "js": ["page-listener.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.aliexpress.com/*", "https://*.aliexpress.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
